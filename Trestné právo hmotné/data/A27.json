  "theory": [
    {
      "heading": "Prijímanie úplatku",
      "text": "Verejný činiteľ alebo iná osoba prijme, žiada alebo si dá sľúbiť úplatok za to, že vykoná alebo nevykoná svoju povinnosť."
    },
    {
      "heading": "Podplácanie",
      "text": "Poskytnutie, ponúknutie alebo sľúbenie úplatku s cieľom ovplyvniť konanie osoby."
    },
    {
      "heading": "Nepriama korupcia",
      "text": "Konanie prostredníka, ktorý úplatok sprostredkuje alebo vybavuje."
    }
  ],
