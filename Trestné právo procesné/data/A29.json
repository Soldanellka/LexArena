  "tiles": [
    { "term": "Právny styk s cudzinou", "definition": "Medzinárodná spolupráca orgánov pri trestnom konaní." },
    { "term": "Medzinárodná právna pomoc", "definition": "Poskytovanie dôkazov, doručovanie a iné úkony medzi štátmi." },
    { "term": "Extradícia", "definition": "Vydanie osoby do iného štátu na trestné stíhanie alebo výkon trestu." },
    { "term": "Európsky zatýkací rozkaz", "definition": "Zjednodušená forma odovzdania osoby medzi členskými štátmi EÚ." },
    { "term": "Doručovanie do cudziny", "definition": "Zasielanie písomností osobám nachádzajúcim sa v inom štáte." },

    { "term": "Právna pomoc", "definition": "Vykonanie procesných úkonov na žiadosť cudzieho štátu." },
    { "term": "Ústredný orgán", "definition": "Orgán koordinujúci medzinárodnú spoluprácu (napr. Ministerstvo spravodlivosti)." },
    { "term": "Prenos trestného konania", "definition": "Postúpenie trestnej veci inému štátu." },
    { "term": "Výkon cudzieho rozhodnutia", "definition": "Uznanie a výkon rozsudku vydaného v inom štáte." },
    { "term": "Zásada reciprocity", "definition": "Spolupráca sa poskytuje, ak ju poskytuje aj druhý štát." }
  ],

