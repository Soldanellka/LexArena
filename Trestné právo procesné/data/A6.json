  "tiles": [
    { "term": "Obhajca", "definition": "Advokát, ktorý poskytuje právnu pomoc obvinenému." },
    { "term": "Povinná obhajoba", "definition": "Situácie, keď obvinený musí mať obhajcu zo zákona." },
    { "term": "Samostatné obhajovacie práva", "definition": "Práva, ktoré môže vykonávať osoba nezávisle od obvineného." },
    { "term": "Mladistvý obvinený", "definition": "Osoba mladšia ako 18 rokov, ktorá má zvýšenú ochranu." },
    { "term": "Ustanovený obhajca", "definition": "Obhajca ustanovený súdom, ak si ho obvinený nezvolí." },

    { "term": "Zvolený obhajca", "definition": "Obhajca, ktorého si obvinený vyberie sám." },
    { "term": "Zúčastnená osoba", "definition": "Osoba, ktorej vec môže byť zhabaná alebo prepadnúť." },
    { "term": "Právo na obhajobu", "definition": "Základné právo obvineného brániť sa proti obvineniu." },
    { "term": "Konflikt záujmov", "definition": "Situácia, keď jeden obhajca nemôže zastupovať viacerých obvinených." },
    { "term": "Právo nevypovedať", "definition": "Obvinený nemusí vypovedať ani usvedčovať sám seba." }
  ],

