  "tiles": [
    { "term": "Hlavné pojednávanie", "definition": "Rozhodujúce štádium trestného konania, v ktorom súd rozhoduje o vine a treste." },
    { "term": "Prednes obžaloby", "definition": "Prokurátor prednesie obžalobu na začiatku pojednávania." },
    { "term": "Vykonávanie dôkazov", "definition": "Súd vykonáva dôkazy výsluchmi, listinami, znaleckými posudkami a ďalšími prostriedkami." },
    { "term": "Záverečné reči", "definition": "Prokurátor, poškodený a obhajca prednesú svoje stanoviská pred rozhodnutím." },
    { "term": "Posledné slovo obvineného", "definition": "Obvinený má právo vyjadriť sa ako posledný pred rozhodnutím." },

    { "term": "Verejnosť pojednávania", "definition": "Hlavné pojednávanie je spravidla verejné, s výnimkami stanovenými zákonom." },
    { "term": "Predseda senátu", "definition": "Osoba, ktorá riadi priebeh hlavného pojednávania." },
    { "term": "Procesná disciplína", "definition": "Súd zabezpečuje poriadok a môže ukladať poriadkové opatrenia." },
    { "term": "Rozsudok", "definition": "Rozhodnutie súdu vo veci samej po vykonaní dôkazov." },
    { "term": "Odročenie pojednávania", "definition": "Súd môže pojednávanie odročiť, ak nie je možné pokračovať." }
  ],

